rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ONE place to set the admin. Paste your UID here (same value
    // as ADMIN_UID in js/firebase-config.js).
    function isAdmin() {
      return request.auth != null && request.auth.uid == "FfORyqwqoMYrmC9iAy8xYQevprG3";
    }

    // Shared market roster. Any signed-in player may run maintenance
    // (bankruptcies / new listings). Friendly-trust model.
    match /market/{docId} {
      allow read, write: if request.auth != null;
    }

    // Player accounts. Everyone signed in can read (leaderboard).
    // Three ways a user doc can be updated:
    //  1. The owner: anything, but cash stays a non-negative number
    //     and any avatar must be a small image data URL.
    //  2. Another player: ONLY cash, and ONLY upward (transfers give,
    //     never take).
    //  3. The admin: ONLY cash, to any non-negative number (treasury).
    match /users/{uid} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.cash == 1000;
      allow update: if request.auth != null && (
        (
          request.auth.uid == uid
          && request.resource.data.cash is number
          && request.resource.data.cash >= 0
          && (
            !("avatar" in request.resource.data)
            || (
              request.resource.data.avatar is string
              && request.resource.data.avatar.size() < 60000
              && request.resource.data.avatar.matches('data:image/(jpeg|png|webp);base64,[A-Za-z0-9+/=]+')
            )
          )
        )
        || (
          request.auth.uid != uid
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["cash"])
          && request.resource.data.cash is number
          && request.resource.data.cash > resource.data.cash
        )
        || (
          isAdmin()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["cash"])
          && request.resource.data.cash is number
          && request.resource.data.cash >= 0
        )
      );

      match /trades/{tradeId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null && request.auth.uid == uid;
      }
    }

    // Transfer log (player-to-player gifts and admin treasury moves).
    // Anyone signed in can read; you can only log transfers you sent.
    match /transfers/{tid} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.from == request.auth.uid;
    }

    // Prediction markets. Only the admin creates/locks/resolves/voids
    // questions. Players write only their own bet doc.
    match /predictions/{predId} {
      allow read: if request.auth != null;
      allow create, update, delete: if isAdmin();

      match /bets/{uid} {
        allow read: if request.auth != null;
        allow create, update: if request.auth != null && request.auth.uid == uid;
      }
    }
  }
}
